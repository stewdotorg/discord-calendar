# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_PUBLIC_KEY=your_public_key_here
DISCORD_GUILD_ID=your_guild_id_here

# Google Calendar
# Preferred: OAuth2 user credentials (enables attendee management)
# Run scripts/setup_oauth.py once to generate the refresh token.
GOOGLE_CLIENT_SECRET_FILE=./client-secret.json
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_CALENDAR_ID=your_calendar_id_here

# Legacy: service account (cannot manage attendees)
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# Server
HOST=0.0.0.0
PORT=8000
